2026-05-31 00:04:51,219 - routers.project_files - DEBUG - Creating new project_files with data: project_id=9 filename='script.js' content='// Todo App - Main Logic\nlet todos = JSON.parse(localStorage.getItem(\'todos\')) || [];\nlet currentFilter = \'all\';\n\n// Initialize the app\ndocument.addEventListener(\'DOMContentLoaded\', () => {\n    renderTodos();\n    updateCount();\n});\n\n// Add todo on Enter key\ndocument.getElementById(\'todoInput\').addEventListener(\'keypress\', (e) => {\n    if (e.key === \'Enter\') {\n        addTodo();\n    }\n});\n\n// Add a new todo\nfunction addTodo() {\n    const input = document.getElementById(\'todoInput\');\n    const text = input.value.trim();\n\n    if (text === \'\') return;\n\n    const todo = {\n        id: Date.now(),\n        text: text,\n        completed: false,\n        createdAt: new Date().toISOString()\n    };\n\n    todos.unshift(todo);\n    saveTodos();\n    renderTodos();\n    updateCount();\n\n    input.value = \'\';\n    input.focus();\n}\n\n// Toggle todo completion\nfunction toggleTodo(id) {\n    todos = todos.map(todo => {\n        if (todo.id === id) {\n            return { ...todo, completed: !todo.completed };\n        }\n        return todo;\n    });\n\n    saveTodos();\n    renderTodos();\n    updateCount();\n}\n\n// Delete a todo\nfunction deleteTodo(id) {\n    todos = todos.filter(todo => todo.id !== id);\n    saveTodos();\n    renderTodos();\n    updateCount();\n}\n\n// Filter todos\nfunction filterTodos(filter) {\n    currentFilter = filter;\n\n    // Update active filter button\n    document.querySelectorAll(\'.filter-btn\').forEach(btn => {\n        btn.classList.remove(\'active\');\n        if (btn.dataset.filter === filter) {\n            btn.classList.add(\'active\');\n        }\n    });\n\n    renderTodos();\n}\n\n// Clear completed todos\nfunction clearCompleted() {\n    todos = todos.filter(todo => !todo.completed);\n    saveTodos();\n    renderTodos();\n    updateCount();\n}\n\n// Render todos to the DOM\nfunction renderTodos() {\n    const list = document.getElementById(\'todoList\');\n    let filteredTodos = todos;\n\n    // Apply filter\n    if (currentFilter === \'active\') {\n        filteredTodos = todos.filter(todo => !todo.completed);\n    } else if (currentFilter === \'completed\') {\n        filteredTodos = todos.filter(todo => todo.completed);\n    }\n\n    // Show empty state if no todos\n    if (filteredTodos.length === 0) {\n        list.innerHTML = `\n            <div class="empty-state">\n                <div class="emoji">📝</div>\n                <p>${currentFilter === \'all\' ? \'No todos yet. Add one above!\' : `No ${currentFilter} todos.`}</p>\n            </div>\n        `;\n        return;\n    }\n\n    // Render todo items\n    list.innerHTML = filteredTodos.map(todo => `\n        <li class="todo-item ${todo.completed ? \'completed\' : \'\'}">\n            <div class="checkbox ${todo.completed ? \'checked\' : \'\'}" onclick="toggleTodo(${todo.id})"></div>\n            <span class="todo-text">${escapeHtml(todo.text)}</span>\n            <button class="delete-btn" onclick="deleteTodo(${todo.id})" title="Delete">✕</button>\n        </li>\n    `).join(\'\');\n}\n\n// Update item count\nfunction updateCount() {\n    const activeCount = todos.filter(todo => !todo.completed).length;\n    const countText = `${activeCount} item${activeCount !== 1 ? \'s\' : \'\'} left`;\n    document.getElementById(\'itemCount\').textContent = countText;\n}\n\n// Save todos to localStorage\nfunction saveTodos() {\n    localStorage.setItem(\'todos\', JSON.stringify(todos));\n}\n\n// Escape HTML to prevent XSS\nfunction escapeHtml(text) {\n    const div = document.createElement(\'div\');\n    div.textContent = text;\n    return div.innerHTML;\n}' file_type='js'
