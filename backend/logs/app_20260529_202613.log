n\n.filter-btn.active {\n    background-color: #e94560;\n    border-color: #e94560;\n    color: white;\n}\n\n#todoList {\n    list-style: none;\n    max-height: 350px;\n    overflow-y: auto;\n}\n\n#todoList::-webkit-scrollbar {\n    width: 6px;\n}\n\n#todoList::-webkit-scrollbar-track {\n    background: transparent;\n}\n\n#todoList::-webkit-scrollbar-thumb {\n    background-color: #0f3460;\n    border-radius: 3px;\n}\n\n.todo-item {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    padding: 14px 16px;\n    background-color: #0f3460;\n    border-radius: 10px;\n    margin-bottom: 10px;\n    transition: transform 0.2s, opacity 0.3s;\n    animation: slideIn 0.3s ease;\n}\n\n@keyframes slideIn {\n    from {\n        opacity: 0;\n        transform: translateY(-10px);\n    }\n    to {\n        opacity: 1;\n        transform: translateY(0);\n    }\n}\n\n.todo-item:hover {\n    transform: translateX(4px);\n}\n\n.todo-item.completed .todo-text {\n    text-decoration: line-through;\n    color: #7a7a9d;\n}\n\n.todo-checkbox {\n    width: 22px;\n    height: 22px;\n    border: 2px solid #e94560;\n    border-radius: 50%;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n    transition: background-color 0.3s;\n}\n\n.todo-checkbox:hover {\n    background-color: rgba(233, 69, 96, 0.2);\n}\n\n.todo-checkbox.checked {\n    background-color: #e94560;\n}\n\n.todo-checkbox.checked::after {\n    content: '✓';\n    color: white;\n    font-size: 12px;\n    font-weight: bold;\n}\n\n.todo-text {\n    flex: 1;\n    font-size: 1rem;\n    word-break: break-word;\n}\n\n.delete-btn {\n    background: none;\n    border: none;\n    color: #7a7a9d;\n    font-size: 1.2rem;\n    cursor: pointer;\n    padding: 4px 8px;\n    border-radius: 6px;\n    transition: color 0.3s, background-color 0.3s;\n    opacity: 0;\n}\n\n.todo-item:hover .delete-btn {\n    opacity: 1;\n}\n\n.delete-btn:hover {\n    color: #e94560;\n    background-color: rgba(233, 69, 96, 0.1);\n}\n\n.footer {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-top: 20px;\n    padding-top: 16px;\n    border-top: 1px solid #0f3460;\n}\n\n#itemCount {\n    font-size: 0.85rem;\n    color: #7a7a9d;\n}\n\n#clearCompleted {\n    background: none;\n    border: none;\n    color: #7a7a9d;\n    cursor: pointer;\n    font-size: 0.85rem;\n    transition: color 0.3s;\n}\n\n#clearCompleted:hover {\n    color: #e94560;\n}\n\n.empty-state {\n    text-align: center;\n    padding: 40px 20px;\n    color: #7a7a9d;\n    font-size: 0.95rem;\n}\n" file_type='css'
